{
  "$schema": "node_modules/wrangler/config-schema.json",
  "compatibility_date": "2025-12-26",
  "name": "skland-daily-attendance-zxy",
  "compatibility_flags": ["nodejs_als"],
  "observability": {
    "enabled": true
  },
  "kv_namespaces": [
    {
      "binding": "KV","id": "ff3fd4e5409243238357c92dd8ae4c66"
    }
  ],
  "triggers": {
    "crons": ["30 0/2 * * *"]
  }
}
